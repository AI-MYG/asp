# ASP Context Infrastructure — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# --- GitHub ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Central triage repo (this repo)
GITHUB_CENTRAL_REPO=AI-MYG/asp
# Default assignee login for cross-surface issues
GITHUB_ASSIGNEE=marviny

# --- Feishu ---
# Webhook for requirement status notifications
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
# Bitable App Token (demand pool)
FEISHU_BITABLE_APP_TOKEN=xxxxxxxx
FEISHU_BITABLE_TABLE_ID=xxxxxxxx
# Feishu App credentials (for API calls)
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxx

# --- AI 后端（Pipeline C/D 的写代码/分析/审查 Agent）---
# 换 AI 只改这一行 ASP_AGENT_BACKEND，无需改任何代码。可选值：
#   claude   = 本机 claude CLI 无头模式（默认，推荐用于后台定时任务，稳定无 TTY 限制）
#   cursor   = 本机 cursor-agent CLI（团队用 Cursor 时选这个）
#              ⚠️ Cursor 无头模式需真实 TTY，只适合"人手动跑一次"，
#                 不适合后台定时任务（会挂死）。定时任务请用 claude。
#   opencode = 遗留 OpenCode Server 方案（需 rootgrove opencode_job.py）
ASP_AGENT_BACKEND=claude
#
# —— 各后端的额外配置 ——
# [claude] Windows 专属：claude CLI 需要 git-bash，指向你的 bash.exe（mac/Linux 不需要）。
# CLAUDE_CODE_GIT_BASH_PATH=C:\Program Files\Git\bin\bash.exe
# [claude] 可选：claude 可执行文件路径（不在 PATH 时用）。
# CLAUDE_CLI_PATH=
# [cursor] 必填：Cursor API Key（cursor-agent 用它认证）。从 Cursor 设置里获取。
# CURSOR_API_KEY=
# [cursor] 可选：cursor-agent 可执行文件路径（不在 PATH 时用）。
# CURSOR_CLI_PATH=

# --- AI code review loop (Pipeline D) ---
# After implementation, a second agent reviews the diff against the analysis
# before push/PR; reworks up to MAX_ROUNDS, then hands off to a human.
ASP_REVIEW_ENABLED=true
ASP_REVIEW_MAX_ROUNDS=2
# Review agent model. Empty = CLI default (sonnet), which strictly obeys the
# JSON output format. Avoid opus here: in headless it tends to emit a markdown
# report instead of pure JSON, breaking verdict parsing.
ASP_REVIEW_MODEL=

# --- OpenCode Server (Local Agent) ---
OPENCODE_HOST=localhost
OPENCODE_PORT=4096
OPENCODE_USER=user
OPENCODE_PASS=changeme
# Model chain: try first model, fallback to next
OPENCODE_MODEL_CHAIN=claude-sonnet-4-20250514,anthropic:claude-sonnet-4-20250514

# --- Agent Client (Pipeline C analysis) ---
# Timeout for agent analysis calls (seconds)
AGENT_CLIENT_TIMEOUT=3600
# Max parallel agent processes for issue_scanner --parallel
MAX_PARALLEL_AGENTS=3

# --- Worktree Root ---
# 各 surface 相对 local_path（如 admin=asp-admin）的解析基准目录。
#   Windows 示例: ASP_WORKTREE_ROOT=D:\work\asp
#   macOS 示例:   ASP_WORKTREE_ROOT=~/CursorWorks/rootgrove
ASP_WORKTREE_ROOT=~/CursorWorks/rootgrove

# --- Observer / Reflector ---
# GitHub org to scan for ASP signals
OBSERVER_GITHUB_ORG=AI-MYG
# Repos to scan (comma-separated)
OBSERVER_REPOS=asp-backend,asp-app,asp-admin,asp-wecom,asp-websites,asp-canonical,asp
# Observer output path (relative to this repo root)
OBSERVER_OUTPUT=memory/OBSERVATIONS.md
