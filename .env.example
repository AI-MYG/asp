# ASP Context Infrastructure — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# --- GitHub ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Central triage repo (this repo)
GITHUB_CENTRAL_REPO=AI-MYG/asp
# Default assignee login for cross-surface issues
GITHUB_ASSIGNEE=marviny

# --- Feishu ---
# Webhook for requirement status notifications
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx
# Bitable App Token (demand pool)
FEISHU_BITABLE_APP_TOKEN=xxxxxxxx
FEISHU_BITABLE_TABLE_ID=xxxxxxxx
# Feishu App credentials (for API calls)
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxx

# --- OpenCode Server (Local Agent) ---
OPENCODE_HOST=localhost
OPENCODE_PORT=4096
OPENCODE_USER=user
OPENCODE_PASS=changeme
# Model chain: try first model, fallback to next
OPENCODE_MODEL_CHAIN=claude-sonnet-4-20250514,anthropic:claude-sonnet-4-20250514

# --- Agent Client (Pipeline C analysis) ---
# Timeout for agent analysis calls (seconds)
AGENT_CLIENT_TIMEOUT=3600
# Max parallel agent processes for issue_scanner --parallel
MAX_PARALLEL_AGENTS=3

# --- Worktree Root ---
# Root directory containing the git worktrees (projects/asp/backend etc.)
# Used by sync_worktrees.py to resolve surface local_path values
ASP_WORKTREE_ROOT=~/CursorWorks/rootgrove

# --- Observer / Reflector ---
# GitHub org to scan for ASP signals
OBSERVER_GITHUB_ORG=AI-MYG
# Repos to scan (comma-separated)
OBSERVER_REPOS=asp-backend,asp-app,asp-admin,asp-wecom,asp-websites,asp-canonical,asp
# Observer output path (relative to this repo root)
OBSERVER_OUTPUT=memory/OBSERVATIONS.md
